<!DOCTYPE html>
<html>
<head>
<title>ASTRA | Dashboard</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Segoe UI',Arial;background:#0F172A;color:white}
.navbar{background:#1E1B4B;padding:16px 32px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #4F46E5}
.logo{font-size:24px;font-weight:bold;color:#4F46E5}
.container{padding:32px;max-width:1400px;margin:0 auto}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:32px}
.stat-card,.card{background:#1E1B4B;border-radius:16px;padding:24px}
.stat-value{font-size:36px;font-weight:bold;color:#4F46E5}
.card{margin-bottom:24px}
input,select,textarea{width:100%;padding:12px;margin:10px 0;border-radius:8px;border:none;background:#0F172A;color:white}
button{background:#4F46E5;color:white;padding:12px 24px;border:none;border-radius:8px;cursor:pointer}
button:hover{background:#6366F1}
.task{background:#0F172A;border-radius:12px;padding:16px;margin-bottom:12px}
.task-header{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap}
.badge{padding:4px 12px;border-radius:20px;font-size:12px}
.badge.pending{background:#F59E0B}
.badge.in_progress{background:#06B6D4}
.badge.done{background:#10B981}
.overdue{background:#EF4444;padding:2px 8px;border-radius:12px;font-size:11px;margin-left:8px}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.admin-panel{border:1px solid #4F46E5}
.user-row{display:flex;justify-content:space-between;align-items:center;padding:12px;border-bottom:1px solid #333}
.search-box input{background:#1E1B4B}
.greeting{font-size:14px;color:#94A3B8}
.productivity-score{background:#4F46E5;border-radius:12px;padding:20px;text-align:center}
.score-value{font-size:48px;font-weight:bold}
.welcome-card{background:linear-gradient(135deg,#4F46E5,#9333EA);border-radius:16px;padding:24px;margin-bottom:24px}
.project-card{background:#0F172A;border-radius:12px;padding:15px;margin-bottom:12px;display:flex;justify-content:space-between}
.health-on{background:#10B981;padding:4px 12px;border-radius:20px;font-size:11px}
.motivation-card{background:linear-gradient(135deg,#1E1B4B,#0F172A);border-radius:16px;padding:20px;text-align:center;border:1px solid #4F46E5}
.footer{text-align:center;padding:30px;color:#94A3B8;font-size:12px;border-top:1px solid #333;margin-top:30px}
</style>
</head>
<body>

<nav class="navbar">
<div class="logo">✨ ASTRA</div>
<div>
<span class="greeting"><%= greeting || 'Welcome' %>, <%= user?.username || 'User' %></span>
<span style="background:#4F46E5;padding:4px 12px;border-radius:20px;margin-left:10px">
<%= user?.role || 'member' %>
</span>
<a href="/logout" style="color:white;margin-left:20px">Logout</a>
</div>
</nav>

<div class="container">

<div class="welcome-card">
<h2>👋 Welcome to ASTRA, <%= user?.username || 'User' %>!</h2>
<p style="margin-top:8px;opacity:0.9">Built for high-performance teams. Trusted by builders.</p>
</div>

<div class="motivation-card" id="motivationWidget">✨ Loading...</div>

<div class="stats-grid">
<div class="stat-card"><div class="stat-value" id="totalTasks">0</div><div>Total Tasks</div></div>
<div class="stat-card"><div class="stat-value" id="completedTasks">0</div><div>Completed</div></div>
<div class="stat-card"><div class="stat-value" id="pendingTasks">0</div><div>Pending</div></div>
<div class="stat-card"><div class="stat-value" id="overdueCount">0</div><div>Overdue</div></div>
</div>

<div class="productivity-score">
<div class="score-value" id="productivityScore">0%</div>
<div>Your Productivity Score</div>
</div>

<div class="productivity-score" style="background:#6366F1;margin-top:12px">
<div class="score-value" id="teamScore">0%</div>
<div>Team Efficiency</div>
</div>

<div class="card">
<div style="background:#333;border-radius:10px;height:10px">
<div id="progressBar" style="background:#4F46E5;width:0%;height:10px;border-radius:10px"></div>
</div>
</div>

<div class="search-box">
<input type="text" id="searchInput" placeholder="🔍 Search tasks..." onkeyup="searchTasks()">
</div>

<div class="grid-2">

<div class="card">
<h3>📁 Projects</h3>

<% if(isAdmin) { %>
<form id="projectForm">
<input type="text" id="projectName" placeholder="Project name" required>
<button type="submit">+ Create</button>
</form>
<% } %>

<div id="projectList"></div>
</div>

<div class="card">
<h3>➕ Assign Task</h3>
<form id="taskForm">
<input type="text" id="taskTitle" placeholder="Task title" required>
<textarea id="taskDesc" placeholder="Description"></textarea>
<select id="taskProject"></select>
<input type="date" id="taskDueDate">
<button type="submit">+ Assign</button>
</form>
</div>

</div>

<div class="card">
<h3>📋 Recent Activity</h3>
<div id="activityList"></div>
</div>

<div class="card">
<h3>📋 My Tasks</h3>
<div id="tasksList"></div>
</div>

<% if(isAdmin) { %>
<div class="card admin-panel">
<h3>👑 Admin Panel</h3>
<h4>All Users | Team: <span id="teamCount">0</span></h4>
<div id="allUsersList"></div>
</div>
<% } %>

<div class="footer">
Built with precision by Jiya Bhagwani ✨ | ASTRA
</div>

</div>

<script>
let allTasks = [];
let allProjects = [];
let allUsers = [];

function escapeHtml(s){
  if(!s) return '';
  return s.replace(/[&<>]/g,m=>m==='&'?'&amp;':m==='<'?'&lt;':'&gt;');
}

function loadData(){
  fetch('/api/data')
    .then(r=>r.json())
    .then(d=>{
      allTasks=d.tasks||[];
      allProjects=d.projects||[];
      updateStats();
      renderProjects();
      renderTasks();
      updateMotivation();
      updateTeamScore();
    });

  fetch('/api/users')
    .then(r=>r.json())
    .then(u=>{
      allUsers=u||[];
      const tc=document.getElementById('teamCount');
      if(tc) tc.innerText=allUsers.length;

      const usersList=document.getElementById('allUsersList');
      if(usersList){
        usersList.innerHTML=allUsers.map(user=>`
          <div class="user-row">
            <span>👤 ${escapeHtml(user.username)}</span>
          </div>
        `).join('');
      }
    });
}

function updateStats(){
  let total=allTasks.length;
  let completed=allTasks.filter(t=>t.status==='done').length;
  let pending=total-completed;
  let overdue=allTasks.filter(t=>t.due_date && new Date(t.due_date)<new Date() && t.status!=='done').length;
  let percent=total===0?0:Math.round((completed/total)*100);

  document.getElementById('totalTasks').innerText=total;
  document.getElementById('completedTasks').innerText=completed;
  document.getElementById('pendingTasks').innerText=pending;
  document.getElementById('overdueCount').innerText=overdue;
  document.getElementById('productivityScore').innerText=percent+'%';
  document.getElementById('progressBar').style.width=percent+'%';
}

function updateTeamScore(){
  let total=allTasks.length;
  let completed=allTasks.filter(t=>t.status==='done').length;
  let percent=total===0?0:Math.round((completed/total)*100);

  document.getElementById('teamScore').innerText=percent+'%';
}

function updateMotivation(){
  let pending=allTasks.filter(t=>t.status!=='done').length;

  document.getElementById('motivationWidget').innerHTML =
    pending===0 ? '🎉 Perfect! All done!' :
    `✨ ${pending} pending — let’s ship! 🚀`;
}

function renderProjects(){
  let c=document.getElementById('projectList');

  if(!allProjects.length){
    c.innerHTML='<div>No projects yet</div>';
    return;
  }

  c.innerHTML=allProjects.map(p=>`
    <div class="project-card">
      <div>📌 ${escapeHtml(p.name)}</div>
      <div><span class="health-on">🟢 Active</span></div>
    </div>
  `).join('');

  let options=allProjects.map(p=>`<option value="${p.id}">${escapeHtml(p.name)}</option>`).join('');
  document.getElementById('taskProject').innerHTML=options;
}

function renderTasks(){
  let c=document.getElementById('tasksList');

  if(!allTasks.length){
    c.innerHTML='<div>No tasks yet</div>';
    return;
  }

  c.innerHTML=allTasks.map(t=>`
    <div class="task">
      <div class="task-header">
        <strong>${escapeHtml(t.title)}</strong>
        <span class="badge ${t.status}">${t.status}</span>
      </div>
      <div>📁 ${escapeHtml(t.project_name || 'No project')}</div>
      <div>${escapeHtml(t.description || '')}</div>
    </div>
  `).join('');
}

function searchTasks(){
  let term=document.getElementById('searchInput').value.toLowerCase();

  document.querySelectorAll('.task').forEach(task=>{
    task.style.display = task.innerText.toLowerCase().includes(term) ? 'block' : 'none';
  });
}

document.getElementById('projectForm')?.addEventListener('submit', function(e){
  e.preventDefault();

  fetch('/projects', {
    method:'POST',
    headers:{'Content-Type':'application/x-www-form-urlencoded'},
    body:'name='+encodeURIComponent(document.getElementById('projectName').value)
  }).then(()=>location.reload());
});

document.getElementById('taskForm')?.addEventListener('submit', function(e){
  e.preventDefault();

  let fd=new URLSearchParams();
  fd.append('title', document.getElementById('taskTitle').value);
  fd.append('description', document.getElementById('taskDesc').value);
  fd.append('project_id', document.getElementById('taskProject').value);
  fd.append('due_date', document.getElementById('taskDueDate').value);

  fetch('/tasks', {
    method:'POST',
    body:fd
  }).then(()=>location.reload());
});

loadData();
</script>

</body>
</html>

<!-- FIXED views/dashboard.ejs -->
<!-- MAIN FIXES:
1. Safe null checks
2. Admin-safe rendering
3. No dashboard crash if announcements missing
4. No JS crash if forms missing
5. Better fallback values
-->

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ASTRA | Ocean Command Center</title>

<style>
:root{
  --bg:#07111F;
  --bg2:#0B1D33;
  --card:rgba(255,255,255,0.08);
  --border:rgba(255,255,255,0.08);
  --text:#F8FAFC;
  --muted:#94A3B8;
  --accent:#38BDF8;
  --accent2:#0EA5E9;
  --teal:#14B8A6;
  --purple:#818CF8;
  --warning:#F59E0B;
  --success:#10B981;
  --danger:#EF4444;
  --shadow:0 20px 50px rgba(0,0,0,0.35);
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  font-family:Inter,Segoe UI,sans-serif;
  background:
    radial-gradient(circle at top right, rgba(56,189,248,0.12), transparent 30%),
    radial-gradient(circle at bottom left, rgba(20,184,166,0.10), transparent 25%),
    linear-gradient(180deg,var(--bg),var(--bg2));
  color:var(--text);
  min-height:100vh;
}

.navbar{
  position:sticky;
  top:0;
  z-index:100;
  backdrop-filter:blur(18px);
  background:rgba(7,17,31,0.85);
  border-bottom:1px solid var(--border);
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:18px 36px;
}

.logo{
  font-size:28px;
  font-weight:900;
  background:linear-gradient(135deg,var(--accent),var(--teal));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.nav-right{
  display:flex;
  align-items:center;
  gap:16px;
  flex-wrap:wrap;
}

.role{
  padding:8px 16px;
  border-radius:999px;
  background:linear-gradient(135deg,var(--accent),var(--purple));
  font-size:13px;
  font-weight:700;
}

.logout{
  color:white;
  text-decoration:none;
}

.container{
  max-width:1600px;
  margin:auto;
  padding:32px;
}

.hero{
  background:linear-gradient(135deg,rgba(56,189,248,0.18),rgba(20,184,166,0.14));
  border:1px solid var(--border);
  border-radius:32px;
  padding:36px;
  margin-bottom:24px;
  box-shadow:var(--shadow);
}

.hero h1{
  font-size:40px;
  margin-bottom:10px;
}

.hero p{
  color:var(--muted);
}

.announcement{
  margin-top:18px;
  padding:14px;
  border-radius:18px;
  background:rgba(255,255,255,0.06);
  color:#E0F2FE;
}

.stats-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:20px;
  margin-bottom:28px;
}

.card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:26px;
  padding:24px;
  box-shadow:var(--shadow);
  backdrop-filter:blur(18px);
}

.stat{
  text-align:center;
}

.stat h2{
  font-size:42px;
  color:var(--accent);
}

.stat p{
  color:var(--muted);
}

.search{
  margin-bottom:20px;
}

.section-grid{
  display:grid;
  grid-template-columns:1.1fr 0.9fr;
  gap:24px;
  margin-bottom:24px;
}

.section-title{
  margin-bottom:18px;
  font-size:22px;
  font-weight:800;
}

input,select,textarea{
  width:100%;
  background:rgba(255,255,255,0.06);
  color:white;
  border:1px solid rgba(255,255,255,0.06);
  padding:14px;
  margin-bottom:14px;
  border-radius:16px;
}

button{
  width:100%;
  border:none;
  padding:14px;
  border-radius:16px;
  cursor:pointer;
  color:white;
  font-weight:800;
  background:linear-gradient(135deg,var(--accent),var(--teal));
}

.task,.project,.user{
  padding:16px;
  border-radius:18px;
  background:rgba(255,255,255,0.04);
  margin-bottom:14px;
}

.top{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:8px;
  gap:10px;
}

.badge{
  padding:5px 12px;
  border-radius:999px;
  font-size:11px;
  font-weight:700;
}

.pending{background:var(--warning);}
.in_progress{background:var(--accent2);}
.done{background:var(--success);}

.admin-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:18px;
}

.empty{
  text-align:center;
  color:var(--muted);
  padding:24px;
}

.footer{
  text-align:center;
  margin-top:32px;
  color:var(--muted);
  font-size:13px;
}

@media(max-width:1100px){
  .section-grid,.admin-grid{
    grid-template-columns:1fr;
  }

  .hero h1{
    font-size:30px;
  }

  .container{
    padding:18px;
  }
}
</style>
</head>

<body>

<nav class="navbar">
  <div class="logo">🌊 ASTRA</div>

  <div class="nav-right">
    <span>
      <%= typeof greeting !== 'undefined' ? greeting : 'Welcome' %>,
      <%= user && user.username ? user.username : 'User' %>
    </span>

    <span class="role">
      <%= user && user.role ? user.role : 'member' %>
    </span>

    <a href="/logout" class="logout">Logout</a>
  </div>
</nav>

<div class="container">

  <section class="hero">
    <h1>Ocean Command Center</h1>
    <p>Minimal. Strategic. Enterprise-grade execution for elite teams.</p>

    <% if (typeof announcement !== 'undefined' && announcement && announcement.message) { %>
      <div class="announcement">
        📢 <%= announcement.message %>
      </div>
    <% } %>
  </section>

  <section class="stats-grid">
    <div class="card stat">
      <h2 id="totalTasks">0</h2>
      <p>Total Missions</p>
    </div>

    <div class="card stat">
      <h2 id="completedTasks">0</h2>
      <p>Completed</p>
    </div>

    <div class="card stat">
      <h2 id="pendingTasks">0</h2>
      <p>Pending</p>
    </div>

    <div class="card stat">
      <h2 id="efficiencyScore">0%</h2>
      <p>Efficiency</p>
    </div>
  </section>

  <div class="search">
    <input
      type="text"
      id="searchInput"
      placeholder="🔎 Search missions..."
      onkeyup="searchTasks()"
    >
  </div>

  <section class="section-grid">

    <div class="card">
      <h2 class="section-title">📁 Project Dock</h2>

      <form id="projectForm">
        <input
          type="text"
          id="projectName"
          placeholder="Launch new project"
          required
        >

        <button type="submit">
          Launch Project
        </button>
      </form>

      <div id="projectList"></div>
    </div>

    <div class="card">
      <h2 class="section-title">🚀 Mission Assignment</h2>

      <form id="taskForm">
        <input
          type="text"
          id="taskTitle"
          placeholder="Mission title"
          required
        >

        <textarea
          id="taskDesc"
          placeholder="Mission details"
        ></textarea>

        <select id="taskProject"></select>

        <select id="assignedTo"></select>

        <select id="priority">
          <option value="low">Low Priority</option>
          <option value="medium" selected>Medium Priority</option>
          <option value="high">High Priority</option>
        </select>

        <input type="date" id="taskDueDate">

        <button type="submit">
          Deploy Mission
        </button>
      </form>
    </div>

  </section>

  <section class="card">
    <h2 class="section-title">📋 Live Mission Feed</h2>
    <div id="tasksList"></div>
  </section>

  <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
  <section class="card">
    <h2 class="section-title">👑 Admin Command Center</h2>

    <div class="admin-grid">

      <div>
        <h3 style="margin-bottom:14px;">
          📢 Broadcast Announcement
        </h3>

        <form method="POST" action="/admin/announcement">
          <textarea
            name="message"
            placeholder="Broadcast to all members..."
            required
          ></textarea>

          <button type="submit">
            Send Broadcast
          </button>
        </form>
      </div>

      <div>
        <h3 style="margin-bottom:14px;">
          👥 Team Members
        </h3>

        <div id="allUsersList"></div>
      </div>

    </div>

    <div style="margin-top:24px;">
      <h3 style="margin-bottom:14px;">
        📊 Team Intelligence
      </h3>

      <div id="adminStats"></div>
    </div>

  </section>
  <% } %>

  <div class="footer">
    Built by Jiya Bhagwani ✨ | ASTRA Ocean OS
  </div>

</div>

<script>
let allTasks = [];
let allProjects = [];
let allUsers = [];

function escapeHtml(str){
  if(!str) return '';

  return str.replace(/[&<>"]/g, m => ({
    '&':'&amp;',
    '<':'&lt;',
    '>':'&gt;',
    '"':'&quot;'
  })[m]);
}

function loadData(){
  Promise.all([
    fetch('/api/data')
      .then(r=>r.json())
      .catch(()=>({tasks:[],projects:[]})),

    fetch('/api/users')
      .then(r=>r.json())
      .catch(()=>([]))
  ])
  .then(([data, users])=>{
    allTasks = data.tasks || [];
    allProjects = data.projects || [];
    allUsers = users || [];

    updateStats();
    renderProjects();
    renderTasks();
    populateAssignDropdown();

    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
      renderUsers();
      loadAdminStats();
    <% } %>
  });
}

function updateStats(){
  const total = allTasks.length;
  const completed = allTasks.filter(
    t=>t.status==='done'
  ).length;

  const pending = allTasks.filter(
    t=>t.status!=='done'
  ).length;

  const efficiency = total===0
    ? 0
    : Math.round((completed/total)*100);

  document.getElementById('totalTasks').innerText = total;
  document.getElementById('completedTasks').innerText = completed;
  document.getElementById('pendingTasks').innerText = pending;
  document.getElementById('efficiencyScore').innerText = efficiency + '%';
}

function renderProjects(){
  const container = document.getElementById('projectList');
  const taskProject = document.getElementById('taskProject');

  if(!container || !taskProject) return;

  if(!allProjects.length){
    container.innerHTML = `<div class="empty">No active projects</div>`;
    taskProject.innerHTML = `<option value="">No Project</option>`;
    return;
  }

  container.innerHTML = allProjects.map(project=>`
    <div class="project">
      <div class="top">
        <strong>${escapeHtml(project.name)}</strong>
      </div>
    </div>
  `).join('');

  taskProject.innerHTML = `
    <option value="">No Project</option>
    ${allProjects.map(project=>`
      <option value="${project.id}">
        ${escapeHtml(project.name)}
      </option>
    `).join('')}
  `;
}

function populateAssignDropdown(){
  const select = document.getElementById('assignedTo');

  if(!select) return;

  select.innerHTML = `
    <option value="">Assign To Me</option>
    ${allUsers.map(user=>`
      <option value="${user.id}">
        ${escapeHtml(user.username)}
      </option>
    `).join('')}
  `;
}

function renderTasks(){
  const container = document.getElementById('tasksList');

  if(!container) return;

  if(!allTasks.length){
    container.innerHTML = `
      <div class="empty">
        No missions deployed yet
      </div>
    `;
    return;
  }

  container.innerHTML = allTasks.map(task=>`
    <div class="task">
      <div class="top">
        <strong>${escapeHtml(task.title)}</strong>

        <span class="badge ${task.status || 'pending'}">
          ${escapeHtml(task.status || 'pending')}
        </span>
      </div>

      <div>
        ${escapeHtml(task.description || '')}
      </div>

      <div style="margin-top:8px;color:var(--muted);font-size:13px;">
        📁 ${escapeHtml(task.project_name || 'No Project')}
        | 👤 ${escapeHtml(task.assigned_to_name || 'User')}
        | Priority: ${escapeHtml(task.priority || 'medium')}
      </div>

      <form method="POST" action="/tasks/${task.id}/status" style="margin-top:12px;">
        <select name="status" onchange="this.form.submit()">
          <option value="pending" ${task.status==='pending'?'selected':''}>Pending</option>
          <option value="in_progress" ${task.status==='in_progress'?'selected':''}>In Progress</option>
          <option value="done" ${task.status==='done'?'selected':''}>Done</option>
        </select>
      </form>
    </div>
  `).join('');
}

function renderUsers(){
  const container = document.getElementById('allUsersList');

  if(!container) return;

  container.innerHTML = allUsers.map(user=>`
    <div class="user">
      👤 ${escapeHtml(user.username)} — ${escapeHtml(user.role || 'member')}
    </div>
  `).join('');
}

function loadAdminStats(){
  fetch('/api/admin/stats')
    .then(r=>r.ok ? r.json() : null)
    .then(stats=>{
      const adminStats = document.getElementById('adminStats');

      if(!adminStats) return;

      if(!stats){
        adminStats.innerHTML = `
          <div class="empty">
            Admin analytics unavailable
          </div>
        `;
        return;
      }

      adminStats.innerHTML = `
        <div class="project">👥 Total Team: ${stats.totalUsers || 0}</div>
        <div class="project">📁 Total Projects: ${stats.totalProjects || 0}</div>
        <div class="project">📋 Total Tasks: ${stats.totalTasks || 0}</div>
        <div class="project">⚡ Team Efficiency: ${stats.teamEfficiency || 0}%</div>
        <div class="project">⚠️ Overdue Missions: ${stats.overdueTasks || 0}</div>
      `;
    });
}

function searchTasks(){
  const input = document.getElementById('searchInput');

  if(!input) return;

  const term = input.value.toLowerCase();

  document.querySelectorAll('.task').forEach(task=>{
    task.style.display = task.innerText
      .toLowerCase()
      .includes(term)
      ? 'block'
      : 'none';
  });
}

document.getElementById('projectForm')?.addEventListener('submit', function(e){
  e.preventDefault();

  fetch('/projects',{
    method:'POST',
    headers:{
      'Content-Type':'application/x-www-form-urlencoded'
    },
    body:'name='+encodeURIComponent(
      document.getElementById('projectName').value
    )
  }).then(()=>location.reload());
});

document.getElementById('taskForm')?.addEventListener('submit', function(e){
  e.preventDefault();

  const data = new URLSearchParams();

  data.append(
    'title',
    document.getElementById('taskTitle').value
  );

  data.append(
    'description',
    document.getElementById('taskDesc').value
  );

  data.append(
    'project_id',
    document.getElementById('taskProject').value
  );

  data.append(
    'assigned_to',
    document.getElementById('assignedTo').value
  );

  data.append(
    'priority',
    document.getElementById('priority').value
  );

  data.append(
    'due_date',
    document.getElementById('taskDueDate').value
  );

  fetch('/tasks',{
    method:'POST',
    body:data
  }).then(()=>location.reload());
});

loadData();
</script>

</body>
</html>

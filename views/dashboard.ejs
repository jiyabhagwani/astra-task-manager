<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ASTRA | Dashboard</title>

<style>
:root{
  --bg:#0B1120;
  --card:#111827;
  --card2:#1F2937;
  --accent:#6366F1;
  --accent2:#8B5CF6;
  --text:#F9FAFB;
  --muted:#94A3B8;
  --success:#10B981;
  --warning:#F59E0B;
  --danger:#EF4444;
  --border:rgba(255,255,255,0.06);
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  font-family:Inter,Segoe UI,Arial,sans-serif;
  background:linear-gradient(180deg,#0B1120,#111827);
  color:var(--text);
  min-height:100vh;
}

.navbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:20px 40px;
  background:rgba(17,24,39,0.9);
  backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
  position:sticky;
  top:0;
  z-index:100;
}

.logo{
  font-size:28px;
  font-weight:800;
  color:var(--accent);
  letter-spacing:1px;
}

.nav-right{
  display:flex;
  align-items:center;
  gap:14px;
}

.role-badge{
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  padding:8px 14px;
  border-radius:999px;
  font-size:13px;
  font-weight:600;
}

.logout{
  color:white;
  text-decoration:none;
  opacity:0.9;
}

.container{
  max-width:1450px;
  margin:auto;
  padding:32px;
}

.hero{
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  border-radius:24px;
  padding:34px;
  margin-bottom:26px;
  box-shadow:0 20px 50px rgba(99,102,241,0.25);
}

.hero h1{
  font-size:34px;
  margin-bottom:10px;
}

.hero p{
  opacity:0.92;
  font-size:16px;
}

.motivation{
  background:rgba(17,24,39,0.8);
  border:1px solid var(--border);
  border-radius:18px;
  padding:18px;
  text-align:center;
  margin-bottom:24px;
  color:var(--muted);
}

.stats-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:20px;
  margin-bottom:26px;
}

.stat-card{
  background:rgba(17,24,39,0.85);
  border:1px solid var(--border);
  border-radius:22px;
  padding:28px;
  text-align:center;
}

.stat-value{
  font-size:42px;
  font-weight:800;
  color:var(--accent);
}

.stat-label{
  color:var(--muted);
  margin-top:8px;
}

.score-card{
  background:linear-gradient(135deg,var(--accent),#4F46E5);
  border-radius:24px;
  padding:28px;
  text-align:center;
  margin-bottom:18px;
}

.score-value{
  font-size:58px;
  font-weight:900;
}

.progress-shell{
  height:12px;
  background:#1F2937;
  border-radius:999px;
  overflow:hidden;
  margin-top:18px;
}

.progress-bar{
  height:100%;
  width:0%;
  background:linear-gradient(90deg,var(--accent),var(--accent2));
}

.search{
  margin:26px 0;
}

.search input{
  width:100%;
  padding:16px;
  border:none;
  border-radius:16px;
  background:rgba(17,24,39,0.9);
  color:white;
  font-size:15px;
}

.grid-2{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:24px;
}

.card{
  background:rgba(17,24,39,0.88);
  border:1px solid var(--border);
  border-radius:24px;
  padding:24px;
  margin-bottom:24px;
}

.card h2{
  margin-bottom:18px;
  font-size:22px;
}

input,textarea,select{
  width:100%;
  padding:14px;
  margin-bottom:14px;
  border:none;
  border-radius:14px;
  background:#0F172A;
  color:white;
}

button{
  width:100%;
  padding:14px;
  border:none;
  border-radius:14px;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  color:white;
  font-weight:700;
  cursor:pointer;
}

.task,.project{
  background:#0F172A;
  padding:18px;
  border-radius:16px;
  margin-bottom:14px;
}

.task-top,.project-top{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:10px;
}

.badge{
  padding:6px 12px;
  border-radius:999px;
  font-size:12px;
}

.pending{background:var(--warning)}
.in_progress{background:#06B6D4}
.done{background:var(--success)}

.empty{
  text-align:center;
  color:var(--muted);
  padding:30px 0;
}

.footer{
  text-align:center;
  margin-top:30px;
  color:var(--muted);
  font-size:13px;
}

@media(max-width:980px){
  .grid-2{
    grid-template-columns:1fr;
  }

  .navbar{
    padding:18px;
  }

  .container{
    padding:18px;
  }

  .hero h1{
    font-size:26px;
  }
}
</style>
</head>

<body>

<nav class="navbar">
  <div class="logo">✨ ASTRA</div>

  <div class="nav-right">
    <span><%= greeting || 'Welcome' %>, <%= user?.username || 'User' %></span>
    <span class="role-badge"><%= user?.role || 'member' %></span>
    <a href="/logout" class="logout">Logout</a>
  </div>
</nav>

<div class="container">

  <section class="hero">
    <h1>👋 Welcome back, <%= user?.username || 'User' %></h1>
    <p>Your premium execution workspace for projects, productivity, and team flow.</p>
  </section>

  <div class="motivation" id="motivationWidget">✨ Preparing your command center...</div>

  <section class="stats-grid">
    <div class="stat-card">
      <div class="stat-value" id="totalTasks">0</div>
      <div class="stat-label">Total Tasks</div>
    </div>

    <div class="stat-card">
      <div class="stat-value" id="completedTasks">0</div>
      <div class="stat-label">Completed</div>
    </div>

    <div class="stat-card">
      <div class="stat-value" id="pendingTasks">0</div>
      <div class="stat-label">Pending</div>
    </div>

    <div class="stat-card">
      <div class="stat-value" id="overdueTasks">0</div>
      <div class="stat-label">Overdue</div>
    </div>
  </section>

  <section class="score-card">
    <div class="score-value" id="productivityScore">0%</div>
    <div>Your Productivity Score</div>

    <div class="progress-shell">
      <div class="progress-bar" id="progressBar"></div>
    </div>
  </section>

  <div class="search">
    <input type="text" id="searchInput" placeholder="🔍 Search tasks..." onkeyup="searchTasks()">
  </div>

  <div class="grid-2">

    <div class="card">
      <h2>📁 Projects</h2>

      <form id="projectForm">
        <input type="text" id="projectName" placeholder="New project name" required>
        <button type="submit">Create Project</button>
      </form>

      <div id="projectList"></div>
    </div>

    <div class="card">
      <h2>➕ New Task</h2>

      <form id="taskForm">
        <input type="text" id="taskTitle" placeholder="Task title" required>
        <textarea id="taskDesc" placeholder="Task description"></textarea>
        <select id="taskProject"></select>
        <input type="date" id="taskDueDate">
        <button type="submit">Create Task</button>
      </form>
    </div>

  </div>

  <div class="card">
    <h2>📋 My Tasks</h2>
    <div id="tasksList"></div>
  </div>

  <% if(isAdmin) { %>
  <div class="card">
    <h2>👑 Team Members</h2>
    <div id="allUsersList"></div>
  </div>
  <% } %>

  <div class="footer">
    Built with precision by Jiya Bhagwani ✨ | ASTRA
  </div>

</div>

<script>
let allTasks = [];
let allProjects = [];
let allUsers = [];

function escapeHtml(str){
  if(!str) return '';
  return str.replace(/[&<>"]/g, tag => ({
    '&':'&amp;',
    '<':'&lt;',
    '>':'&gt;',
    '"':'&quot;'
  }[tag] || tag));
}

function loadData(){
  Promise.all([
    fetch('/api/data').then(r=>r.json()).catch(()=>({tasks:[],projects:[]})),
    fetch('/api/users').then(r=>r.json()).catch(()=>([]))
  ])
  .then(([data, users])=>{
    allTasks = data.tasks || [];
    allProjects = data.projects || [];
    allUsers = users || [];

    updateStats();
    renderProjects();
    renderTasks();
    renderUsers();
    updateMotivation();
  });
}

function updateStats(){
  const total = allTasks.length;
  const completed = allTasks.filter(t=>t.status==='done').length;
  const pending = allTasks.filter(t=>t.status!=='done').length;
  const overdue = allTasks.filter(t=>t.due_date && new Date(t.due_date)<new Date() && t.status!=='done').length;

  const score = total===0 ? 0 : Math.round((completed/total)*100);

  document.getElementById('totalTasks').innerText = total;
  document.getElementById('completedTasks').innerText = completed;
  document.getElementById('pendingTasks').innerText = pending;
  document.getElementById('overdueTasks').innerText = overdue;
  document.getElementById('productivityScore').innerText = score + '%';
  document.getElementById('progressBar').style.width = score + '%';
}

function updateMotivation(){
  const pending = allTasks.filter(t=>t.status!=='done').length;

  document.getElementById('motivationWidget').innerHTML =
    pending===0
    ? '🎉 You are fully clear — create your next breakthrough.'
    : `🚀 ${pending} mission${pending!==1?'s':''} pending. Stay sharp.`;
}

function renderProjects(){
  const list = document.getElementById('projectList');

  if(!allProjects.length){
    list.innerHTML = `<div class="empty">No projects yet</div>`;
  } else {
    list.innerHTML = allProjects.map(project=>`
      <div class="project">
        <div class="project-top">
          <strong>${escapeHtml(project.name)}</strong>
        </div>
      </div>
    `).join('');
  }

  document.getElementById('taskProject').innerHTML =
    allProjects.map(project=>`
      <option value="${project.id}">
        ${escapeHtml(project.name)}
      </option>
    `).join('');
}

function renderTasks(){
  const list = document.getElementById('tasksList');

  if(!allTasks.length){
    list.innerHTML = `<div class="empty">No tasks yet</div>`;
    return;
  }

  list.innerHTML = allTasks.map(task=>`
    <div class="task">
      <div class="task-top">
        <strong>${escapeHtml(task.title)}</strong>
        <span class="badge ${task.status}">
          ${escapeHtml(task.status)}
        </span>
      </div>

      <div>${escapeHtml(task.description || '')}</div>
      <small>📁 ${escapeHtml(task.project_name || 'No Project')}</small>
    </div>
  `).join('');
}

function renderUsers(){
  const list = document.getElementById('allUsersList');
  if(!list) return;

  list.innerHTML = allUsers.map(user=>`
    <div class="task">
      👤 ${escapeHtml(user.username)} — ${escapeHtml(user.role)}
    </div>
  `).join('');
}

function searchTasks(){
  const term = document.getElementById('searchInput').value.toLowerCase();

  document.querySelectorAll('.task').forEach(task=>{
    task.style.display =
      task.innerText.toLowerCase().includes(term)
      ? 'block'
      : 'none';
  });
}

document.getElementById('projectForm')?.addEventListener('submit', function(e){
  e.preventDefault();

  fetch('/projects',{
    method:'POST',
    headers:{'Content-Type':'application/x-www-form-urlencoded'},
    body:'name='+encodeURIComponent(document.getElementById('projectName').value)
  }).then(()=>location.reload());
});

document.getElementById('taskForm')?.addEventListener('submit', function(e){
  e.preventDefault();

  const data = new URLSearchParams();
  data.append('title', document.getElementById('taskTitle').value);
  data.append('description', document.getElementById('taskDesc').value);
  data.append('project_id', document.getElementById('taskProject').value);
  data.append('due_date', document.getElementById('taskDueDate').value);

  fetch('/tasks',{
    method:'POST',
    body:data
  }).then(()=>location.reload());
});

loadData();
</script>

</body>
</html>

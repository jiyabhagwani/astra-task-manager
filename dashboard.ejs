<!DOCTYPE html>
<html>
<head>
  <title>Task Manager Dashboard</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:Arial;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);min-height:100vh}
    .container{max-width:1200px;margin:0 auto;padding:20px}
    .header{background:white;padding:20px;border-radius:12px;margin-bottom:25px;display:flex;justify-content:space-between;align-items:center}
    .header h1{color:#667eea}
    .user-badge{background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;padding:8px 16px;border-radius:25px}
    .logout-btn{color:#dc3545;text-decoration:none}
    .card{background:white;border-radius:12px;padding:25px;margin-bottom:25px}
    .card h3{margin-bottom:20px;border-left:4px solid #667eea;padding-left:12px}
    input,select,textarea{width:100%;padding:12px;border:1px solid #ddd;border-radius:8px;margin-bottom:12px}
    button{background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;border:none;padding:12px 24px;border-radius:8px;cursor:pointer}
    .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:25px}
    .project-item,.task{padding:12px;border-bottom:1px solid #eee}
    .task-header{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap}
    .badge{padding:4px 12px;border-radius:20px;font-size:11px}
    .badge.pending{background:#ffc107}
    .badge.in_progress{background:#17a2b8;color:white}
    .badge.done{background:#28a745;color:white}
    .alert{background:#ffeaa7;padding:15px;border-radius:10px;margin-bottom:20px;border-left:4px solid #e17055}
    .filters{display:flex;gap:15px;margin-bottom:20px;flex-wrap:wrap}
    .search-box{flex:1}
    .search-box input{width:100%;padding:12px;border:1px solid #ddd;border-radius:25px}
    .filter-btn{padding:8px 16px;border:1px solid #ddd;background:white;border-radius:25px;cursor:pointer}
    .filter-btn.active{background:#667eea;color:white}
    .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:25px}
    .stat-card{background:white;border-radius:12px;padding:20px;text-align:center}
    .stat-number{font-size:32px;font-weight:bold;color:#667eea}
    .progress-container{background:#eee;border-radius:10px;height:10px;margin:15px 0}
    .progress-bar{background:linear-gradient(135deg,#28a745 0%,#20c997 100%);height:10px;border-radius:10px;width:0%}
    .toast{position:fixed;bottom:20px;right:20px;background:#28a745;color:white;padding:12px 24px;border-radius:8px;display:none}
    @media (max-width:768px){.grid-2,.stats-grid{grid-template-columns:1fr}}
  </style>
</head>
<body>
<div class="container">
<div class="header">
<h1>📋 Task Manager</h1>
<div><span class="user-badge">👤 <%= user.username %> (<%= user.role %>)</span>
<a href="/logout" class="logout-btn">🚪 Logout</a></div></div>

<div class="stats-grid">
<div class="stat-card"><div class="stat-number" id="totalTasks">0</div><div class="stat-label">Total Tasks</div></div>
<div class="stat-card"><div class="stat-number" id="completedTasks">0</div><div class="stat-label">Completed</div></div>
<div class="stat-card"><div class="stat-number" id="pendingTasks">0</div><div class="stat-label">Pending</div></div>
<div class="stat-card"><div class="stat-number" id="overdueCount">0</div><div class="stat-label">Overdue</div></div>
</div>

<div class="card"><h3>📊 Progress</h3><div class="progress-container"><div class="progress-bar" id="progressBar"></div></div><p style="text-align:center" id="progressText">0% Complete</p></div>

<div id="overdueAlert" style="display:none" class="alert">⚠️ Overdue Tasks! Please update them.</div>

<div class="card"><h3>🔍 Search & Filter</h3><div class="filters"><div class="search-box"><input type="text" id="searchInput" placeholder="Search tasks..." onkeyup="filterTasks()"></div>
<div><button class="filter-btn active" onclick="filterByStatus('all')">All</button>
<button class="filter-btn" onclick="filterByStatus('pending')">Pending</button>
<button class="filter-btn" onclick="filterByStatus('in_progress')">In Progress</button>
<button class="filter-btn" onclick="filterByStatus('done')">Done</button></div></div></div>

<div class="grid-2">
<div class="card"><h3>📁 Projects</h3>
<form id="projectForm"><input type="text" id="projectName" placeholder="Project name" required><button type="submit">+ Create Project</button></form>
<div id="projectList" style="margin-top:20px"></div></div>

<div class="card"><h3>➕ Add New Task</h3>
<form id="taskForm"><input type="text" id="taskTitle" placeholder="Task title" required>
<textarea id="taskDesc" placeholder="Description" rows="3"></textarea>
<select id="taskProject"><option value="">Select Project</option></select>
<input type="date" id="taskDueDate"><button type="submit">+ Add Task</button></form></div>
</div>

<div class="card"><h3>📋 My Tasks</h3><div id="tasksList"></div></div>

<% if(isAdmin) { %>
<div class="card"><h3>👑 Admin Panel</h3>
<form method="POST" action="/projects/1/add-member"><select name="project_id" id="adminProjectSelect"></select>
<input type="text" name="username" placeholder="Username to add"><button type="submit">+ Add to Project</button></form>
<div><h4>All Users</h4><div id="allUsersList"></div></div></div>
<% } %>
</div>
<div id="toast" class="toast"></div>

<script>
let allTasks=[],allProjects=[],currentFilter='all',currentSearch='';
function loadData(){fetch('/api/data').then(r=>r.json()).then(d=>{allTasks=d.tasks||[];allProjects=d.projects||[];updateStats();renderProjects();renderTasks()})}
function updateStats(){let total=allTasks.length,completed=allTasks.filter(t=>t.status==='done').length,pending=total-completed,overdue=allTasks.filter(t=>t.due_date&&new Date(t.due_date)<new Date()&&t.status!=='done').length,percent=total===0?0:(completed/total)*100;
document.getElementById('totalTasks').innerText=total;document.getElementById('completedTasks').innerText=completed;document.getElementById('pendingTasks').innerText=pending;document.getElementById('overdueCount').innerText=overdue;
document.getElementById('progressBar').style.width=percent+'%';document.getElementById('progressText').innerText=Math.round(percent)+'% Complete';
document.getElementById('overdueAlert').style.display=overdue>0?'block':'none';}
function renderProjects(){let html=!allProjects.length?'<div style="color:#999">No projects yet</div>':allProjects.map(p=>'<div class="project-item">📌 '+escapeHtml(p.name)+'</div>').join('');
document.getElementById('projectList').innerHTML=html;
let opts='<option value="">Select Project</option>'+allProjects.map(p=>'<option value="'+p.id+'">'+escapeHtml(p.name)+'</option>').join('');
if(document.getElementById('taskProject'))document.getElementById('taskProject').innerHTML=opts;
if(document.getElementById('adminProjectSelect'))document.getElementById('adminProjectSelect').innerHTML=opts;}
function renderTasks(){let filtered=allTasks;if(currentFilter!=='all')filtered=filtered.filter(t=>t.status===currentFilter);
if(currentSearch)filtered=filtered.filter(t=>t.title.toLowerCase().includes(currentSearch.toLowerCase()));
if(!filtered.length){document.getElementById('tasksList').innerHTML='<div style="color:#999;text-align:center">No tasks found</div>';return;}
document.getElementById('tasksList').innerHTML=filtered.map(t=>'<div class="task"><div class="task-header"><div><span class="task-title">'+escapeHtml(t.title)+'</span> <span class="badge '+t.status+'">'+t.status+'</span>'+(t.due_date&&new Date(t.due_date)<new Date()&&t.status!=='done'?' <span style="background:#dc3545;color:white;padding:2px 8px;border-radius:12px">OVERDUE</span>':'')+'</div><form method="POST" action="/tasks/'+t.id+'/status" style="margin:0"><select name="status" onchange="this.form.submit()"><option value="pending" '+(t.status==='pending'?'selected':'')+'>Pending</option><option value="in_progress" '+(t.status==='in_progress'?'selected':'')+'>In Progress</option><option value="done" '+(t.status==='done'?'selected':'')+'>Done</option></select></form></div><div class="task-meta">📁 '+escapeHtml(t.project_name||'No project')+(t.due_date?' | 📅 '+t.due_date:'')+'</div>'+(t.description?'<div>'+escapeHtml(t.description)+'</div>':'')+'</div>').join('');}
function filterByStatus(s){currentFilter=s;document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));event.target.classList.add('active');renderTasks();}
function filterTasks(){currentSearch=document.getElementById('searchInput').value;renderTasks();}
function showToast(m){let t=document.getElementById('toast');t.innerText=m;t.style.display='block';setTimeout(()=>t.style.display='none',2000);}
function escapeHtml(s){if(!s)return '';return s.replace(/[&<>]/g,function(m){if(m==='&')return '&amp;';if(m==='<')return '&lt;';if(m==='>')return '&gt;';return m;});}
document.getElementById('projectForm')?.addEventListener('submit',function(e){e.preventDefault();fetch('/projects',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'name='+encodeURIComponent(document.getElementById('projectName').value)}).then(()=>{showToast('Project created!');setTimeout(()=>location.reload(),500)});});
document.getElementById('taskForm')?.addEventListener('submit',function(e){e.preventDefault();let fd=new URLSearchParams();fd.append('title',document.getElementById('taskTitle').value);fd.append('description',document.getElementById('taskDesc').value);fd.append('project_id',document.getElementById('taskProject').value);fd.append('due_date',document.getElementById('taskDueDate').value);fetch('/tasks',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:fd}).then(()=>{showToast('Task created!');setTimeout(()=>location.reload(),500)});});
loadData();
<% if(isAdmin) { %>fetch('/api/users').then(r=>r.json()).then(users=>{if(document.getElementById('allUsersList')){document.getElementById('allUsersList').innerHTML=users.map(u=>'<div style="display:flex;justify-content:space-between;padding:8px;border-bottom:1px solid #eee"><span>👤 '+escapeHtml(u.username)+' ('+u.role+')</span>'+(u.role!=='admin'?'<form method="POST" action="/make-admin/'+u.id+'" style="margin:0"><button type="submit" style="background:#28a745;padding:4px 12px">Make Admin</button></form>':'<span>Admin</span>')+'</div>').join('')}});<% } %>
</script>
</body>
</html>